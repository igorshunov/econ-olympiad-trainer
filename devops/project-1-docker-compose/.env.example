# EconTrainer — env-конфигурация (12-factor).
# Скопируйте в .env и подставьте свои значения.

# Image tag (для воспроизводимости в production указывайте конкретный sha-tag).
TAG=latest

# PostgreSQL (используется будущим бэкендом)
POSTGRES_DB=econtrainer
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-me-please

# Порты на host (для деплоя за reverse-proxy — обычно 80/443).
HTTP_PORT=80
HTTPS_PORT=443
